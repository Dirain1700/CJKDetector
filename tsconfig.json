{
    "compilerOptions": {
        // module settings

        // emit settings
        "target": "esnext",
        "rootDir": "./",
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "esModuleInterop": true,
        "forceConsistentCasingInFileNames": true,

        // type checks
        "skipLibCheck": true,
        "strict": true,
        "noImplicitReturns": true,
        "noImplicitAny": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": true,
        "strictBindCallApply": true,
        "noPropertyAccessFromIndexSignature": false,
        "types": ["node"],
        "typeRoots": ["node_modules/@types", "types"]
    },
    "include": ["build.ts", "src/**/*.ts", "types/**/*.ts"],
    "exclude": ["src/type/*", "src/test/**/*.ts"]
}
