{
    "name": "@dirain/cjkdetector",
    "version": "1.0.3",
    "description": "A package for detecting Chinese and Japanese characters",
    "main": "./dist/cjs/index.js",
    "exports": {
        "import": "./dist/esm/index.js",
        "require": "./dist/cjs/index.js"
    },
    "types": "./src/index.ts",
    "module": "./dist/esm/index.js",
    "files": [
        "dist",
        "src",
        "types",
        "unihan_data"
    ],
    "type": "commonjs",
    "bin": {
        "cjkdetector": "./dist/setup/cli.js"
    },
    "devDependencies": {
        "@eslint/compat": "^2.0.5",
        "@eslint/eslintrc": "^3.3.5",
        "@eslint/js": "9.39.4",
        "@types/lodash": "^4.17.24",
        "@types/mocha": "^10.0.10",
        "@types/node": "^25.6.0",
        "@typescript-eslint/eslint-plugin": "8.58.2",
        "@typescript-eslint/parser": "8.58.2",
        "esbuild": "0.28.0",
        "esbuild-plugin-alias-path": "2.0.2",
        "eslint": "9.39.4",
        "eslint-import-resolver-typescript": "4.4.4",
        "eslint-plugin-import": "2.32.0",
        "glob": "13.0.6",
        "globals": "^17.5.0",
        "lodash": "^4.18.1",
        "mocha": "^11.7.5",
        "prettier": "3.8.2",
        "ts-node": "10.9.2",
        "typescript": "6.0.2"
    },
    "scripts": {
        "lint": "eslint --cache .",
        "lint-fix": "eslint --cache --fix .",
        "test": "npm run esbuild && npm run mocha",
        "mocha": "npm run esbuild && mocha --enable-source-maps dist/cjs/test/index.js",
        "write": "prettier --write .",
        "check": "prettier --check .",
        "tsc": "npm run tsc:main && npm run tsc:setup && npm run tsc:test",
        "tsc:main": "tsc -p tsconfig.json --noEmit",
        "tsc:setup": "tsc -p setup/tsconfig.json --noEmit",
        "tsc:test": "tsc -p src/test/tsconfig.json --noEmit",
        "emit": "npm run emit:cjs && npm run emit:esm",
        "emit:cjs": "tsc -p tsconfig.emit.json --emitDeclarationOnly --outDir dist/cjs --module commonjs",
        "emit:esm": "tsc -p tsconfig.emit.json --emitDeclarationOnly --outDir dist/esm --module esnext",
        "ci": "npm run check && npm run lint && npm run tsc",
        "build": "npm run write && npm run esbuild && npm run emit && npm run lint",
        "pre-build": "tsc -p tsconfig.build.json",
        "setup": "node --enable-source-maps dist/setup/setup.js",
        "esbuild": "npm run pre-build && node --enable-source-maps build.js",
        "prepublishOnly": "npm run check && npm run pre-build && npm run build",
        "ncu": "npx -p npm-check-updates  -c \"ncu -u\""
    },
    "author": "Dirain1700",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/Dirain1700/cjkdetector.git"
    },
    "overrides": {
        "diff": "9.0.0",
        "serialize-javascript": "7.0.5"
    }
}
